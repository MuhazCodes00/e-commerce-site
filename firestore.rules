rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================
    // PRODUCTS (public read)
    // =========================
    match /mob_products/{productId} {
      allow read: if true;

      // only admin can write (you will secure later with auth)
      allow write: if false;
    }

    // =========================
    // ORDERS
    // =========================
    match /mob_orders/{orderId} {

      // customers can create orders
      allow create: if true;

      // prevent public reading/updating orders
      allow read, update, delete: if false;
    }

    // =========================
    // SETTINGS (admin only)
    // =========================
    match /mob_settings/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}